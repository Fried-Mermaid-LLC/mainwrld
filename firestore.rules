rules_version = '2';

// MainWRLD Firestore Security Rules
//
// Replaces the previous client-side ADMIN_USERNAMES check in App.tsx:249
// with server-side authorization via Firebase custom claims. The admin
// claim is granted from the `setAdmin` Cloud Function (see functions/).
//
// Read access defaults to "must be signed in" for everything except the
// usernames lookup (needed before sign-in to resolve username → email)
// and the public app config (spotlight book of the week).
//
// IMPORTANT — `request.auth.token.username` custom claim:
// Several rules below check `request.auth.token.username` because the
// existing data model (chatMessages.from/to, relationships.admirer/target,
// notifications.recipient) uses USERNAMES, not uids. The custom claim is
// set by the `onUserCreate` Cloud Function (see functions/) the first
// time a user document lands in Firestore. After signup the client must
// call `await user.getIdToken(true)` once to refresh the token and pick
// up the new claim. Existing users will get the claim on their next
// login automatically because the token rotates.
//
// If a user reaches the rules without the username claim (mid-migration,
// races on signup), reads of THEIR chats/notifications will fail.
// Acceptable failure mode: client retries after a token refresh.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ----
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // F04 — a banned account carries the `banned` custom claim (set by the
    // banUser Cloud Function). Secondary guard: the Auth record is also
    // disabled + tokens revoked, but this blocks writes from a still-valid
    // stale token in the window before the claim propagates / token expires.
    function isBanned() {
      return isSignedIn() && request.auth.token.banned == true;
    }

    // ---- users ----
    // Profile docs. Anyone signed in can read profiles (the app shows
    // them in lists, the 3D world, comments). Only the owner can write,
    // except admins who can update any profile (e.g. strikes, ban).
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isUser(uid);
      // The owner may update their own profile, EXCEPT the Stripe Connect payout
      // mirror fields (written only by Cloud Functions) and purchasedBookIds —
      // the permanent paid-entitlement record the chapter paywall trusts. Only
      // the Admin SDK (Stripe webhook / purchaseBooksWithPoints) may grant it,
      // so a client can never self-grant or delete it (that would let anyone
      // read paid books for free). ownedBookIds stays client-writable — it is
      // just library membership (save/remove), NOT a read entitlement.
      allow update: if isAdmin()
        || (isUser(uid)
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['stripeAccountId', 'payoutsEnabled', 'chargesEnabled',
                          'detailsSubmitted', 'stripeAccountUpdatedAt',
                          'purchasedBookIds',
                          // Subscription / renewal mirror — written only by the
                          // Stripe webhook, Apple verifier and reminder cron
                          // (Admin SDK), so a client can't forge membership or
                          // spoof the renewal reminder.
                          'stripeCustomerId', 'stripeSubscriptionId',
                          'premiumProvider', 'premiumRenewalAt',
                          'premiumCancelAtPeriodEnd', 'subscriptionStatus',
                          'renewalReminderSentForAt']));
      allow delete: if isAdmin();
    }

    // ---- usernames ----
    // Public lookup table used by logIn() to resolve username → email
    // *before* the user is authenticated. Stored doc only contains
    // { uid, email } — no PII beyond what the user typed.
    match /usernames/{username} {
      allow read: if true;
      // Only the user themselves can claim/release their username.
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.uid == request.auth.uid;
      // Username records are immutable once claimed (no change of email).
      allow update: if false;
    }

    // ---- books ----
    // Published books are readable by any signed-in user. Drafts only by
    // their author. Anyone signed in can create a book in their name.
    // Updates restricted to author or admin (for take-downs).
    match /books/{bookId} {
      // Published books: any signed-in user. Drafts: only the author (by
      // authorUid — the reliable request.auth.uid, NOT the username custom
      // claim which may be missing mid-signup) or an admin. The client must
      // query published + own-books separately; a listen on the whole
      // collection can't satisfy this condition and is rejected wholesale.
      allow read: if isSignedIn()
        && (resource.data.isDraft != true || resource.data.authorUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && !isBanned()
        && request.resource.data.authorUid == request.auth.uid;
      // Authors may edit their own books, but monetization state is
      // privilege-gated (Phase 2). The submit / review callables write the
      // server-only lifecycle + seller fields via the Admin SDK. A non-admin
      // author may NOT: write those server fields, self-grant isMonetized,
      // change the price while the book stays monetized, or clear the terminal
      // permanence flags. Author un-monetize (isMonetized true→false, price 0)
      // is still allowed so the demonetize/unpublish handlers keep working.
      allow update: if isSignedIn() && (
        isAdmin()
        || (
          resource.data.authorUid == request.auth.uid
          && !isBanned()
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
               'monetizationStatus', 'requestedPrice', 'monetizationRequestedAt',
               'monetizationDenialReason', 'monetizationReviewedAt',
               'monetizationReviewedBy', 'sellerUid', 'sellerStripeAccountId',
               'monetizationAttempts'
             ])
          && !(request.resource.data.get('isMonetized', false) == true
               && resource.data.get('isMonetized', false) != true)
          && !(resource.data.get('isMonetized', false) == true
               && request.resource.data.get('isMonetized', false) == true
               && request.resource.data.get('price', 0) != resource.data.get('price', 0))
          && !(resource.data.get('permanentlyDemonetized', false) == true
               && request.resource.data.get('permanentlyDemonetized', false) != true)
          && !(resource.data.get('wasMonetizedBefore', false) == true
               && request.resource.data.get('wasMonetizedBefore', false) != true)
          // Admin take-down is terminal: a non-admin author may neither clear
          // the takenDown flag nor re-publish a taken-down book (un-draft it).
          && !(resource.data.get('takenDown', false) == true
               && request.resource.data.get('takenDown', true) != true)
          && !(resource.data.get('takenDown', false) == true
               && request.resource.data.get('isDraft', true) == false)
        )
      );
      allow delete: if isSignedIn()
        && (resource.data.authorUid == request.auth.uid || isAdmin());

      // ---- chapter bodies (schema 2) ----
      // Chapter text lives here, out of the book doc, so listings stay light.
      // Direct reads are limited to the author (editor + own preview) and
      // admins. EVERY other reader gets chapter content through the
      // getChapterContent callable, which enforces the paywall server-side
      // (free/preview/purchased). Authors/admins may write; the moderation
      // trigger (Admin SDK) bypasses these rules.
      match /chapters/{chapterId} {
        function parentBook() {
          return get(/databases/$(database)/documents/books/$(bookId)).data;
        }
        allow read: if isSignedIn()
          && (parentBook().authorUid == request.auth.uid || isAdmin());
        allow write: if isSignedIn()
          && (parentBook().authorUid == request.auth.uid || isAdmin());
      }
    }

    // ---- comments ----
    // Any signed-in user can read comments. Only the author can create
    // (with their own uid in authorUid). Updates limited to like-count
    // bumps by other users, or content edits by the author. Deletes by
    // author or admin.
    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && !isBanned()
        && request.resource.data.authorUid == request.auth.uid;
      allow update: if isSignedIn()
        && (resource.data.authorUid == request.auth.uid || isAdmin());
      allow delete: if isSignedIn()
        && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    // ---- chatMessages ----
    // Private DMs. Read/write restricted to the two participants
    // (`from` and `to` fields are usernames per the current schema).
    // We index by username because that's what the app stores. When
    // username changes become possible this needs revisiting.
    match /chatMessages/{msgId} {
      allow read: if isSignedIn() && (
        resource.data.from == request.auth.token.username
        || resource.data.to == request.auth.token.username
        || isAdmin()
      );
      allow create: if isSignedIn() && !isBanned()
        && request.resource.data.from == request.auth.token.username;
      // Updates limited to marking read by the recipient.
      allow update: if isSignedIn()
        && resource.data.to == request.auth.token.username
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['read']);
      allow delete: if isSignedIn() && (
        resource.data.from == request.auth.token.username
        || resource.data.to == request.auth.token.username
        || isAdmin()
      );
    }

    // ---- relationships (admire / follow) ----
    // The doc records `admirer` and `target` usernames. Anyone signed
    // in can read (the app uses these to compute mutual lists). Only
    // the admirer can create or delete their own relationship.
    match /relationships/{relId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && !isBanned()
        && request.resource.data.admirer == request.auth.token.username;
      allow update: if false;
      allow delete: if isSignedIn() && (
        resource.data.admirer == request.auth.token.username
        || isAdmin()
      );
    }

    // ---- notifications ----
    // Only the recipient can read their own notifications. Any signed-
    // in user can create a notification addressed to another user (the
    // app does this client-side on likes/comments/follows). The read
    // flag is the only legitimate update; recipient flips it on read.
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (
        resource.data.recipient == request.auth.token.username
        || isAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && resource.data.recipient == request.auth.token.username
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['read']);
      allow delete: if isSignedIn() && (
        resource.data.recipient == request.auth.token.username
        || isAdmin()
      );
    }

    // ---- reports (UGC moderation queue) ----
    // App Store guideline 1.2 requires a reporting mechanism. Any
    // signed-in user can file a report; only admins can read or
    // change status.
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && !isBanned()
        && request.resource.data.reportedBy == request.auth.token.username;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---- iapTransactions ----
    // Audit trail of verified Apple IAP transactions, written by the
    // verifyAppleReceipt Cloud Function (Stage 3c). Used for replay
    // protection (transactionId is the doc key — duplicates are
    // ignored, restoring a purchase does not re-credit).
    //
    // Users can read their own entries (so the client can prove a
    // purchase was credited). No client writes — only the function,
    // which runs with admin privileges and bypasses these rules.
    match /iapTransactions/{transactionId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ---- bookPurchases (cash + points book sales audit trail) ----
    // Written ONLY by the Stripe webhook / purchaseBooksWithPoints callable
    // (Admin SDK). The buyer and the seller can read their own rows; nobody
    // can write from a client. This is the trustworthy record of a paid book
    // and drives "Purchase History" + permanent ownership of paid books.
    match /bookPurchases/{id} {
      allow read: if isSignedIn() && (
        resource.data.buyerUid == request.auth.uid
        || resource.data.sellerUid == request.auth.uid
        || isAdmin()
      );
      allow write: if false;
    }

    // ---- appConfig ----
    // Global config (spotlight book of the week). Public read so the home
    // screen can show it before sign-in. The Star of the Week is now written
    // ONLY by the scheduled rotateSpotlight / rotateSpotlightNow Cloud Functions
    // (admin SDK, which bypasses rules), so clients may not write it (X04).
    match /appConfig/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
