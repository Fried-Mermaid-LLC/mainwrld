# MainWRLD environment variables
# Copy to .env.local and fill in real values. .env.local is gitignored.
# All client-side vars must be prefixed VITE_ to be exposed to the browser bundle.

# ---- Firebase Web SDK config (mainwrld-f7acf project) ----
# These are not secret — they identify the public Firebase project — but they
# vary between test/staging/prod, so we keep them in env.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ---- Stripe (web-only checkout; iOS build uses Apple IAP) ----
# Publishable keys are safe to ship in the bundle. Secret keys must never
# be put here — they belong on the server.
VITE_STRIPE_PUBLISHABLE_KEY=

# ---- Resend (welcome email) ----
# Used by server.js, not the browser bundle. Keep server-side only.
RESEND_API_KEY=
RESEND_FROM_EMAIL=welcome@mainwrld.com
PORT=3001

# ---- API base URL for the Resend backend ----
# In dev: http://localhost:3001
# In prod: the public URL of the deployed Resend server
VITE_API_BASE_URL=http://localhost:3001
