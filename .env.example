# Local IP address of iOS device for live reload
HOST=

# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
# Realtime Database URL (presence). Must match the native GoogleService-Info.plist
# RTDB instance/region. e.g. https://<project>-default-rtdb.firebaseio.com
VITE_FIREBASE_DATABASE_URL=

# Firebase App Check
VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=
VITE_FIREBASE_RECAPTCHA_SITE_KEY=

# Resend
RESEND_API_KEY=

# Stripe Connect mode (seller payouts / book checkout). Defaults to "test" when
# unset/anything-but-live, so device + dev testing always uses the Stripe TEST
# key. Set to "live" ONLY in the production build env to take real payments.
VITE_STRIPE_MODE=test
