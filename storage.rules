rules_version = '2';

// MainWRLD Firebase Storage rules
//
// Book covers moved out of the Firestore book document (they used to be inlined
// as ~380KB base64 strings, bloating every listings read). They now live here as
// real image files; the book doc keeps only the download URL.
//
// Path: book-covers/{uid}/{bookId}/{fileName}. The author uid is embedded in the
// path so write-ownership can be enforced without a cross-service Firestore read.
// Covers are world-readable because they are shown in public listings/explore.
service firebase.storage {
  match /b/{bucket}/o {
    match /book-covers/{uid}/{bookId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 1 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
