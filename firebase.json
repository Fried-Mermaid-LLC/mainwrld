{
  "hosting": {
    "public": "apps/app/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**", "CNAME"],
    "rewrites": [
      { "source": "/terms", "destination": "/terms.html" },
      { "source": "/privacy", "destination": "/privacy.html" },
      { "source": "/book/**", "function": "ogBook" },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/.well-known/apple-app-site-association",
        "headers": [
          { "key": "Content-Type", "value": "application/json" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs24",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "pnpm -C \"$RESOURCE_DIR\" run lint || true",
        "pnpm -C \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "database": { "port": 9000 },
    "functions": { "port": 5001 },
    "storage": { "port": 9199 },
    "ui": { "enabled": true, "port": 4000 },
    "singleProjectMode": true
  }
}
