{
  "name": "@mainwrld/app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "dev:ios": "cap run ios -l --host $(grep -E '^HOST=' .env.local | cut -d= -f2) --port 5173",
    "build:web": "vite build",
    "build:ios": "npm run build:web && cap sync ios",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor-community/native-audio": "8.0.0",
    "@capacitor-firebase/crashlytics": "8.3.0",
    "@capacitor-firebase/messaging": "8.3.0",
    "@capacitor/app": "8.1.0",
    "@capacitor/browser": "8.0.3",
    "@capacitor/core": "8.4.1",
    "@capacitor/ios": "8.4.1",
    "@capacitor/keyboard": "8.0.5",
    "@capacitor/preferences": "8.0.1",
    "@capacitor/share": "8.0.1",
    "@capacitor/splash-screen": "8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@mainwrld/types": "workspace:*",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@tanstack/react-query": "^5.101.0",
    "cordova-plugin-purchase": "13.17.2",
    "firebase": "12.15.0",
    "obscenity": "0.4.6",
