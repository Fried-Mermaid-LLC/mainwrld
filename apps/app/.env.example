# Local IP address of iOS device for live reload
HOST=

# Firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_AUTH_DOMAIN=
# Realtime Database URL — required for the realtime 3D-world layer (/world).
# When empty, the world layer disables itself (rtdb = null) and the rest of the
# app is unaffected. e.g. https://<project>-default-rtdb.firebaseio.com
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=

# Set to 'true' (dev only) to point the RTDB client at the local Firebase
# emulator (127.0.0.1:9000) instead of the real instance. Web only.
VITE_USE_FIREBASE_EMULATORS=

# Firebase App Check
VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=
VITE_FIREBASE_RECAPTCHA_SITE_KEY=

# Resend
RESEND_API_KEY=

# NestJS API base URL
VITE_API_URL=http://localhost:3000
