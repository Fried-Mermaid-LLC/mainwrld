# Copy to `.env` and fill in. On Cloud Run these are injected from Secret
# Manager / runtime config instead of a file.

NODE_ENV=development
PORT=3000

# Comma-separated CORS allowlist. Empty => reflect request origin (dev only).
# Web dev server + Capacitor (iOS WKWebView origin + dev livereload).
CORS_ORIGINS=http://localhost:5173,capacitor://localhost,http://localhost
SITE_URL=http://localhost:5173

# Shared secret for Cloud Scheduler -> /internal/cron/* (set a random value).
INTERNAL_CRON_SECRET=

# ---- Firebase Admin ----
FIREBASE_PROJECT_ID=mainwrld-f7acf
FIREBASE_STORAGE_BUCKET=mainwrld-f7acf.firebasestorage.app
FIREBASE_DATABASE_URL=https://mainwrld-f7acf-default-rtdb.firebaseio.com
# LOCAL DEV ONLY: path to the service-account JSON (relative to apps/api).
# Leave UNSET on Cloud Run so applicationDefault() uses the runtime SA (ADC).
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# ---- Secrets (fill per domain as it is implemented) ----
RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_TEST_SECRET_KEY=
STRIPE_LIVE_WEBHOOK_SECRET=
STRIPE_TEST_WEBHOOK_SECRET=
OPENAI_API_KEY=
APPLE_ISSUER_ID=
APPLE_KEY_ID=
APPLE_BUNDLE_ID=
APPLE_PRIVATE_KEY=
APPLE_ENV=Sandbox
