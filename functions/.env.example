# Firebase Functions v2 params (firebase-functions/params). Copy to
# `functions/.env` (or `.env.<project-alias>`) and fill in before deploy.
# Non-secret build-time config only — real secrets go in Secret Manager via
# `firebase functions:secrets:set <NAME>`, NOT here.

# Origin of the NestJS API (apps/api) WITHOUT a trailing slash and WITHOUT the
# /api/v1 prefix. Used by the sendRenewalReminders scheduled function to POST the
# API's protected /api/v1/internal/cron/renewal-reminders endpoint.
# e.g. https://mainwrld-api-xxxxxx.uc.run.app  (your Cloud Run service URL)
RENEWAL_API_ORIGIN=

# NOTE: the matching cron secret is a Secret Manager secret, not a param here:
#   firebase functions:secrets:set INTERNAL_CRON_SECRET
# Its value MUST equal the API's INTERNAL_CRON_SECRET env var (apps/api/.env /
# Cloud Run), or the API's CronGuard rejects the call with 401.
